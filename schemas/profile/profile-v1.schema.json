{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.hl7v2-rs.org/profile/v1",
  "title": "HL7v2 Profile Schema",
  "description": "Defines the structure of HL7v2 validation profiles with constraints, rules, and inheritance",
  "type": "object",
  "required": ["message_structure", "version"],
  "properties": {
    "message_structure": {
      "type": "string",
      "description": "HL7 message structure (e.g., ADT^A01, ORU^R01)",
      "pattern": "^[A-Z0-9_\\^]+$",
      "examples": ["ADT^A01", "ORU^R01", "ORM^O01", "ADT_A01", "GENERIC"]
    },
    "version": {
      "type": "string",
      "description": "HL7 version (2.3, 2.4, 2.5, 2.6, 2.7, 2.8, 2.9)",
      "enum": ["2.3", "2.4", "2.5", "2.5.1", "2.6", "2.7", "2.7.1", "2.8", "2.8.1", "2.8.2", "2.9"]
    },
    "parent": {
      "type": "string",
      "description": "Parent profile to inherit from (optional)",
      "examples": ["generic.yaml", "base_adt.yaml"]
    },
    "description": {
      "type": "string",
      "description": "Human-readable description of this profile"
    },
    "constraints": {
      "type": "array",
      "description": "Field-level constraints for validation",
      "items": {
        "$ref": "#/definitions/constraint"
      }
    },
    "rules": {
      "type": "array",
      "description": "Cross-field validation rules",
      "items": {
        "$ref": "#/definitions/rule"
      }
    },
    "tables": {
      "type": "object",
      "description": "Custom value sets for table validation",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "string"
        }
      }
    }
  },
  "definitions": {
    "constraint": {
      "type": "object",
      "required": ["path", "constraint_type"],
      "properties": {
        "path": {
          "type": "string",
          "description": "HL7 field path (e.g., PID.3, MSH.9.1)",
          "pattern": "^[A-Z]{3}(\\.[0-9]+(\\[[0-9]+\\])?(\\.[0-9]+)?)?$",
          "examples": ["PID.3", "MSH.9.1", "OBX.5[1].1"]
        },
        "constraint_type": {
          "type": "string",
          "enum": ["required", "length", "pattern", "table", "data_type"],
          "description": "Type of constraint to apply"
        },
        "severity": {
          "type": "string",
          "enum": ["error", "warning", "info"],
          "default": "error",
          "description": "Severity level for constraint violations"
        },
        "min_length": {
          "type": "integer",
          "minimum": 0,
          "description": "Minimum length for length constraints"
        },
        "max_length": {
          "type": "integer",
          "minimum": 0,
          "description": "Maximum length for length constraints"
        },
        "pattern": {
          "type": "string",
          "description": "Regex pattern for pattern constraints",
          "examples": ["^[0-9]{3}-[0-9]{2}-[0-9]{4}$", "^[A-Z]{2}[0-9]{6}$"]
        },
        "table": {
          "type": "string",
          "description": "HL7 table number or custom table name",
          "examples": ["0001", "0002", "custom_gender"]
        },
        "data_type": {
          "type": "string",
          "enum": ["CX", "PN", "TS", "DT", "TM", "NM", "SI", "FT", "TX", "ST", "ID"],
          "description": "Expected HL7 data type"
        },
        "description": {
          "type": "string",
          "description": "Human-readable description of this constraint"
        }
      }
    },
    "rule": {
      "type": "object",
      "required": ["rule_type"],
      "properties": {
        "rule_type": {
          "type": "string",
          "enum": ["requires", "prohibits", "validates", "temporal", "contextual"],
          "description": "Type of cross-field rule"
        },
        "if_path": {
          "type": "string",
          "description": "Conditional path for contextual rules",
          "pattern": "^[A-Z]{3}(\\.[0-9]+(\\[[0-9]+\\])?(\\.[0-9]+)?)?$"
        },
        "if_value": {
          "type": "string",
          "description": "Value to check in conditional"
        },
        "then_path": {
          "type": "string",
          "description": "Path to validate if condition is met",
          "pattern": "^[A-Z]{3}(\\.[0-9]+(\\[[0-9]+\\])?(\\.[0-9]+)?)?$"
        },
        "then_constraint": {
          "type": "string",
          "enum": ["required", "empty", "matches"],
          "description": "Constraint to apply to then_path"
        },
        "expression": {
          "type": "string",
          "description": "Expression for complex validation",
          "examples": ["PID.7 < MSH.7", "OBX.5 > 0 AND OBX.5 < 100"]
        },
        "severity": {
          "type": "string",
          "enum": ["error", "warning", "info"],
          "default": "error"
        },
        "description": {
          "type": "string",
          "description": "Human-readable description of this rule"
        }
      }
    }
  },
  "examples": [
    {
      "message_structure": "ADT^A01",
      "version": "2.5",
      "description": "Patient admission profile",
      "constraints": [
        {
          "path": "PID.3",
          "constraint_type": "required",
          "severity": "error",
          "description": "Patient ID is required"
        },
        {
          "path": "PID.5",
          "constraint_type": "data_type",
          "data_type": "PN",
          "description": "Patient name must be PN type"
        }
      ],
      "rules": [
        {
          "rule_type": "contextual",
          "if_path": "PV1.2",
          "if_value": "I",
          "then_path": "PV1.3",
          "then_constraint": "required",
          "description": "If patient class is inpatient, bed location is required"
        }
      ]
    }
  ]
}
